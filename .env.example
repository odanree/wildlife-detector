# ── Camera ──────────────────────────────────────────────────────────────────
RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1
RTSP_TRANSPORT=tcp

# ── Detection ────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
INFERENCE_THRESHOLD=0.35
INPUT_WIDTH=1280
INPUT_HEIGHT=720
# Rate-limit VLM calls per track (seconds between calls for the same track)
VLM_INTERVAL_S=2.0

# ── VLM backend ──────────────────────────────────────────────────────────────
# claude | ollama | mock
VLM_BACKEND=claude
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava:7b-v1.6-mistral-q4_K_M

# ── Alerts ───────────────────────────────────────────────────────────────────
HA_WEBHOOK_URL=http://homeassistant.local:8123/api/webhook/rodent_detected
HA_TOKEN=

# ── PTZ / slew-to-zone ───────────────────────────────────────────────────────
# Secondary camera slews to the detection zone on a positive rodent event.
# Save PTZ presets in the NVR UI and map zones → presets in config/detection.yaml.
SLEW_ENABLED=false             # master kill-switch; leave false in dev/replay
SECONDARY_CAMERA_ID=1
SLEW_LOCKOUT_SECONDS=10

# PTZ CGI credentials (Amcrest/Dahua). Falls back to AMCREST_* per-camera.
AMCREST_HOST=192.168.1.100
AMCREST_USER=admin
AMCREST_PASS=password
# PTZ_HOST_1=192.168.1.100     # per-camera overrides (0-based index)
# PTZ_CHANNEL_1=2               # NVR channel for secondary camera (default: id+1)
# PTZ_SPEED=4
# PTZ_PORT=80

# ── Replay / test ───────────────────────────────────────────────────────────
VIDEO_PATH=
VIDEO_LOOP=true
VIDEO_SPEED=1.0

# ── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TZ=UTC

# ── Preview server (optional) ────────────────────────────────────────────────
# Set PREVIEW_ENABLED=true (or pass --preview) to expose a live MJPEG feed
# with annotated YOLO/motion/zone overlays at http://localhost:8000/.
# Zero-op when disabled.
PREVIEW_ENABLED=false
PREVIEW_HOST=0.0.0.0
# Default 8100 to avoid clashing with parking-enforcement-detector (port 8000).
PREVIEW_PORT=8100
PREVIEW_EVERY_N=2                # publish every Nth pipeline frame to save encode cost
PREVIEW_ALERT_FLASH_FRAMES=40    # how long a red alert bbox flashes on the preview
